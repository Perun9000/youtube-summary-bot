TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=5779821
OWNER_USER_ID=
ALLOWED_USERS_PATH=/data/users.json

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4000

LMSTUDIO_BASE_URL=http://host.docker.internal:1234
LMSTUDIO_MODEL=qwen3-8b
LMSTUDIO_API_KEY=
LMSTUDIO_AUTO_LOAD=false
LMSTUDIO_NUM_CTX=16384

# Транскрибация роликов без субтитров — через Groq Whisper API.
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

TELEGRAPH_ACCESS_TOKEN=
TELEGRAPH_AUTHOR_NAME=YouTube Summary Bot

YTDLP_COOKIES_PATH=/data/youtube.cookies.txt
BOT_DATA_DIR=/data
# SQLite-база бота (пользователи, кэш саммари, дайджесты, очередь).
# Необязательно: по умолчанию <BOT_DATA_DIR>/bot.db.
DATABASE_PATH=/data/bot.db
TRANSCRIPT_CHUNK_MAX_CHARS=10000

# Премьеры: через сколько часов после запланированного выхода ролика
# возвращаться за саммари (чтобы успели появиться субтитры).
PREMIERE_SUMMARY_DELAY_HOURS=4

# Иерархический синтез для длинных роликов:
# если чанков >= SYNTHESIS_HIERARCHY_THRESHOLD,
# сначала делаются промежуточные мини-синтезы, и только потом финальная сборка.
SYNTHESIS_HIERARCHY_THRESHOLD=6
SYNTHESIS_GROUP_SIZE=5
